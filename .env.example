# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=true

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wildtrack
POSTGRES_USER=wildtrack
POSTGRES_PASSWORD=wildtrack

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=wildtrack

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wildtrack-media
MINIO_USE_SSL=false
MINIO_PRESIGNED_URL_EXPIRY=900

# ─── MQTT ─────────────────────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=wildtrack-backend
MQTT_USERNAME=wildtrack_device
MQTT_PASSWORD=wildtrack_pass

# ─── Security (fill before any auth work) ────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production

# ─── Admin bootstrap (used by seed script in Slice 1) ────────────────────────
ADMIN_SEED_EMAIL=admin@wildtrack.local
ADMIN_SEED_PASSWORD=ChangeThisImmediately!
